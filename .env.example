DATABASE_URL="postgresql://archive_toybox:archive_toybox@localhost:5433/archive_toybox?schema=public"
# Docker 映射 5433→容器 5432，避免与本机 Postgres（127.0.0.1:5432）冲突
# 若不用 Docker、本机 Postgres 表由系统用户创建，可改为：
# DATABASE_URL="postgresql://YOUR_OS_USER@localhost:5432/archive_toybox?schema=public"
PORT=3000
JWT_SECRET="change-me-in-production"
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
IOS_API_BASE_URL="http://localhost:3000/v1"
