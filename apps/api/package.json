{
  "name": "@archive-toybox/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "prisma:generate": "tsx prisma/run-prisma.ts generate",
    "prisma:migrate": "tsx prisma/run-prisma.ts migrate dev",
    "prisma:deploy": "tsx prisma/run-prisma.ts migrate deploy",
    "prisma:push": "tsx prisma/run-prisma.ts db push",
    "seed": "tsx prisma/seed.ts",
    "test": "tsx --test src/**/*.spec.ts src/ai/schemas/*.spec.ts src/modules/argument/*.spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
